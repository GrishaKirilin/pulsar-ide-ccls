{
  "name": "pulsar-ide-ccls",
  "main": "./lib/main",
  "version": "0.3.0",
  "description": "Provides ccls language-server integration for Pulsar.",
  "keywords": [
    "ccls",
    "ide",
    "C++",
    "cpp",
    "C"
  ],
  "repository": "https://github.com/GrishaKirilin/pulsar-ide-ccls",
  "license": "MIT",
  "engines": {
    "pulsar": "*"
  },
  "dependencies": {
    "@savetheclocktower/atom-languageclient": "^1.17.20",
    "vscode-languageserver-types": "^3.18.0"
  },
  "enhancedScopes": [
    "source.c",
    "source.cpp"
  ],
  "consumedServices": {
    "linter-indie": {
      "versions": {
        "2.0.0": "consumeLinterV2"
      }
    },
    "datatip": {
      "versions": {
        "0.1.0": "consumeDatatip"
      }
    },
    "atom-ide-busy-signal": {
      "versions": {
        "0.1.0": "consumeBusySignal"
      }
    }
  },
  "providedServices": {
    "autocomplete.provider": {
      "versions": {
        "2.0.0": "provideAutocomplete"
      }
    },
    "code-format.range": {
      "versions": {
        "0.1.0": "provideCodeFormat"
      }
    },
    "code-highlight": {
      "versions": {
        "0.1.0": "provideCodeHighlight"
      }
    },
    "definitions": {
      "versions": {
        "0.1.0": "provideDefinitions"
      }
    },
    "find-references": {
      "versions": {
        "0.1.0": "provideFindReferences"
      }
    },
    "outline-view": {
      "versions": {
        "0.1.0": "provideOutlines"
      }
    }
  }
}
